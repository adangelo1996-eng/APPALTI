########################################
# Configurazione ambiente progetto Appalti
# Copia questo file in `.env` e adatta i valori.
########################################

# --- Backend API (FastAPI) ---
# URL di connessione al database Postgres (usato dal backend)
# Esempio locale:
# postgresql+asyncpg://appalti:appalti@localhost:5432/appalti
DATABASE_URL=postgresql+asyncpg://appalti:appalti@localhost:5432/appalti

# Porta di esposizione backend FastAPI
BACKEND_PORT=8000

# --- Supabase (Auth + Storage) ---
# Dati del progetto Supabase, usati sia da backend che da frontend.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=rfp-documents

# --- Frontend (Next.js) ---
# URL base del backend visto dal browser
# Per sviluppo locale con backend su http://localhost:8000:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase lato browser (devono corrispondere a quelli sopra)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

