{
  "name": "rfp-ai-copilot-monorepo",
  "private": true,
  "scripts": {
    "dev:web": "cd apps/web && next dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}

